{
  "rootDirectory": "client",
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "npx tsc -b && npx vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
